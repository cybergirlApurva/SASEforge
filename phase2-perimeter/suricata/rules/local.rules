# Detect port scanning
alert tcp any any -> $HOME_NET any (msg:"Port scan detected"; flags:S; threshold:type threshold, track by_src, count 20, seconds 10; sid:1000001; rev:1;)

# Detect ping sweep
alert icmp any any -> $HOME_NET any (msg:"ICMP ping sweep detected"; itype:8; threshold:type threshold, track by_src, count 5, seconds 5; sid:1000002; rev:1;)

# Detect brute force SSH
alert tcp any any -> $HOME_NET 22 (msg:"SSH brute force attempt"; flags:S; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000003; rev:1;)

# Detect Nmap scan
alert tcp any any -> $HOME_NET any (msg:"Nmap scan detected"; flags:S,12; sid:1000004; rev:1;)
